[Unit]
Description=Cvetik Box Flask application
After=network.target

[Service]
User=cvetikbox
Group=www-data
WorkingDirectory=/srv/cvetik-box
EnvironmentFile=/srv/cvetik-box/.env
RuntimeDirectory=cvetik-box
ExecStart=/srv/cvetik-box/.venv/bin/gunicorn --workers 1 --timeout 90 --bind unix:/run/cvetik-box/cvetik-box.sock wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
